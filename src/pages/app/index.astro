---
import { and, db, desc, eq, ResearchProjects } from "astro:db";
import { AvButton, AvCard, AvContainer, AvInput, AvTextarea } from "@ansiversa/components";
import AppShell from "../../layouts/AppShell.astro";
import { APP_META } from "../../app.meta";
import { createId, getProjectSummary } from "../../lib/research";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");

  if (intent === "create-project") {
    const title = String(formData.get("title") ?? "").trim();
    const description = String(formData.get("description") ?? "").trim();
    const subject = String(formData.get("subject") ?? "").trim();

    if (title) {
      const now = new Date();
      await db.insert(ResearchProjects).values({
        id: createId(),
        userId: user.id,
        title,
        description: description || null,
        subject: subject || null,
        status: "active",
        createdAt: now,
        updatedAt: now,
        archivedAt: null,
      });
    }
  }

  if (intent === "archive-project") {
    const projectId = String(formData.get("projectId") ?? "");
    if (projectId) {
      const now = new Date();
      await db
        .update(ResearchProjects)
        .set({ status: "archived", archivedAt: now, updatedAt: now })
        .where(and(eq(ResearchProjects.id, projectId), eq(ResearchProjects.userId, user.id)));
    }
  }

  if (intent === "restore-project") {
    const projectId = String(formData.get("projectId") ?? "");
    if (projectId) {
      await db
        .update(ResearchProjects)
        .set({ status: "active", archivedAt: null, updatedAt: new Date() })
        .where(and(eq(ResearchProjects.id, projectId), eq(ResearchProjects.userId, user.id)));
    }
  }

  return Astro.redirect("/app");
}

const projects = await db
  .select()
  .from(ResearchProjects)
  .where(eq(ResearchProjects.userId, user.id))
  .orderBy(desc(ResearchProjects.updatedAt));

const activeProjects = projects.filter((project) => project.status === "active");
const archivedProjects = projects.filter((project) => project.status === "archived");

const summary = await getProjectSummary(user.id);

const title = `${APP_META.name} | Research Workspace`;
---

<AppShell title={title} description="Structured research workspace.">
  <section class="av-section">
    <AvContainer>
      <div class="av-auth-stack-lg">
        <AvCard className="av-auth-card">
          <div class="av-auth-stack-sm">
            <p class="av-kicker">Overview</p>
            <h1 class="av-section-title">Research workspace</h1>
            <div class="grid gap-3 md:grid-cols-5">
              <div><strong>{summary.totalProjects}</strong><p class="av-text-soft">Total projects</p></div>
              <div><strong>{summary.activeProjects}</strong><p class="av-text-soft">Active</p></div>
              <div><strong>{summary.archivedProjects}</strong><p class="av-text-soft">Archived</p></div>
              <div><strong>{summary.totalNotes}</strong><p class="av-text-soft">Notes</p></div>
              <div><strong>{summary.importantNotes}</strong><p class="av-text-soft">Important</p></div>
            </div>
          </div>
        </AvCard>

        <AvCard className="av-auth-card">
          <form method="post" class="av-auth-stack-sm">
            <input type="hidden" name="intent" value="create-project" />
            <p class="av-kicker">Projects</p>
            <h2 class="av-card-heading">Create research project</h2>
            <AvInput name="title" label="Title" required placeholder="AI regulation analysis" />
            <AvInput name="subject" label="Subject" placeholder="Policy" />
            <AvTextarea name="description" label="Description" rows={3} placeholder="Scope and context" />
            <AvButton type="submit">Create project</AvButton>
          </form>
        </AvCard>

        <div class="grid gap-4 lg:grid-cols-2">
          <AvCard className="av-auth-card">
            <div class="av-auth-stack-sm">
              <p class="av-kicker">Projects</p>
              <h2 class="av-card-heading">Active</h2>
              {activeProjects.length === 0 ? <p class="av-text-soft">No active projects yet.</p> : null}
              {activeProjects.map((project) => (
                <article class="research-item-card">
                  <div>
                    <a href={`/app/projects/${project.id}`} class="research-link">{project.title}</a>
                    <p class="av-text-soft">{project.subject ?? "General"}</p>
                  </div>
                  <form method="post">
                    <input type="hidden" name="intent" value="archive-project" />
                    <input type="hidden" name="projectId" value={project.id} />
                    <AvButton type="submit" variant="ghost">Archive</AvButton>
                  </form>
                </article>
              ))}
            </div>
          </AvCard>

          <AvCard variant="soft">
            <div class="av-auth-stack-sm">
              <p class="av-kicker">Archived</p>
              <h2 class="av-card-heading">Project history</h2>
              {archivedProjects.length === 0 ? <p class="av-text-soft">No archived projects.</p> : null}
              {archivedProjects.map((project) => (
                <article class="research-item-card">
                  <div>
                    <a href={`/app/projects/${project.id}`} class="research-link">{project.title}</a>
                    <p class="av-text-soft">Archived</p>
                  </div>
                  <form method="post">
                    <input type="hidden" name="intent" value="restore-project" />
                    <input type="hidden" name="projectId" value={project.id} />
                    <AvButton type="submit" variant="ghost">Restore</AvButton>
                  </form>
                </article>
              ))}
            </div>
          </AvCard>
        </div>
      </div>
    </AvContainer>
  </section>
</AppShell>
