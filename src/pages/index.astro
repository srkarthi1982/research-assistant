---
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import AppShell from "../layouts/AppShell.astro";
import { APP_META } from "../app.meta";
import { buildRootRedirect } from "../lib/redirects";

const rootAppUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
const appUrl = new URL("/app", Astro.url).toString();
const startHref = "/app";
const signInHref = buildRootRedirect(rootAppUrl, "/login", appUrl);

const title = `${APP_META.name} | Ansiversa`;
const description = APP_META.description;

const valueCards = [
  {
    "title": "Clarity first",
    "description": "The workspace is built to help questions, notes, and conclusions stay clear instead of scattering across tabs and docs."
  },
  {
    "title": "Built for progress",
    "description": "The workflow keeps one topic in focus so it is easier to think, organize, and return to the work without losing context."
  },
  {
    "title": "Ready for real study flows",
    "description": "Research Assistant follows current Ansiversa standards, giving the product a stable base for deeper research features later."
  }
];
const reasonsToUse = [
  {
    "title": "One clear job",
    "description": "Research Assistant stays anchored to a single purpose so the future product can remain focused instead of sprawling."
  },
  {
    "title": "Shared Ansiversa standards",
    "description": "The landing page, app shell, live preview, navbar, and footer all follow the current ecosystem baseline."
  },
  {
    "title": "Ready for the next implementation phase",
    "description": "Research Assistant now ships with a structured V1 note workflow and a stable base for future research tooling."
  }
];
---

<AppShell title={title} description={description}>
  <section class="av-section">
    <AvContainer>
      <div class="av-auth-stack-lg">
        <AvCard className="av-auth-card">
          <div class="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Learning Mini-App</p>
              <h1 class="av-section-title">Organize your research. Think clearly.</h1>
              <p class="av-text-soft">
                Research Assistant gives you a calm workspace for capturing questions, insights, references, and conclusions in one structured research flow with live preview.
              </p>
            </div>

            <div class="av-row-wrap">
              <AvButton href={startHref}>Open Research Assistant</AvButton>
              <AvButton href={signInHref} variant="ghost">Sign in</AvButton>
            </div>

            <p class="av-text-soft">
              Live now as a focused V1 research workspace, with the core editor and summary flow available directly in the app.
            </p>
          </div>
        </AvCard>

        <div class="grid gap-4 md:grid-cols-3">
          {valueCards.map((card) => (
            <AvCard variant="soft" className="av-auth-stack-sm">
              <h2 class="av-card-heading">{card.title}</h2>
              <p class="av-text-soft">{card.description}</p>
            </AvCard>
          ))}
        </div>

        <div class="grid gap-4 md:grid-cols-[1.1fr_0.9fr]">
          <AvCard variant="soft" className="av-auth-stack-sm">
            <p class="av-kicker">What this app will do</p>
            <h2 class="av-card-heading">Research Assistant</h2>
            <p class="av-text-soft">
              Research Assistant is a focused learning tool inside Ansiversa. Its first release is being shaped around one clear job: Summaries, citations, and structured notes.
            </p>
            <p class="av-text-soft">
              The repo already follows Ansiversa layout, metadata, and route standards, so future work can stay tightly scoped to the actual product workflow.
            </p>
          </AvCard>

          <AvCard className="av-auth-card">
            <div class="av-auth-stack-sm">
              <p class="av-kicker">Category fit</p>
              <h2 class="av-card-heading">Learning</h2>
              <p class="av-text-soft">
                Research Assistant is being positioned with a clarity, progress, and focused understanding tone so it feels consistent with the
                rest of the Ansiversa ecosystem from the first load.
              </p>
            </div>
          </AvCard>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {reasonsToUse.map((reason) => (
            <AvCard variant="soft" className="av-auth-stack-sm">
              <p class="av-kicker">Why use it</p>
              <h2 class="av-card-heading">{reason.title}</h2>
              <p class="av-text-soft">{reason.description}</p>
            </AvCard>
          ))}
        </div>

        <AvCard className="av-auth-card">
          <div class="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Available now</p>
              <h2 class="av-section-title">The V1 research workflow is live and ready to use.</h2>
              <p class="av-text-soft">
                Open the app to organize one research topic clearly, keep the current draft in local storage, and copy a clean structured summary whenever you need it.
              </p>
            </div>

            <div class="av-row-wrap">
              <AvButton href={startHref}>Open Research Assistant</AvButton>
              <AvButton href={signInHref} variant="ghost">Return through Ansiversa</AvButton>
            </div>
          </div>
        </AvCard>
      </div>
    </AvContainer>
  </section>
</AppShell>
